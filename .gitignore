# Root-level ignore for TaskFlow monorepo

# Node dependencies
/node_modules

# Vite build outputs
/client/dist
/client/dist-ssr

# Local environment files
*.env
*.env.*

# Logs
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*
logs
*.log

# Editor and OS files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Generated files
*.log
*.tmp
*.temp

# Optional package managers
package-lock.json
yarn.lock
pnpm-lock.yaml

# Ignore server backend output and dependencies when implemented
/server/node_modules
/server/dist
/server/build
